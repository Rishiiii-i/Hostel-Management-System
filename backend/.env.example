# Backend Environment Variables Template
PORT=5000
JWT_SECRET=smart-hostel-secret-key-change-in-production

# MongoDB Connection String 
MONGODB_URI=mongodb://mongodb:27017/hostel-management

# Firebase Admin Service Account Key Path or JSON String
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
